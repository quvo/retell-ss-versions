{
  "component": {
    "conversation_flow_component_id": "cf-component-location-preferred",
    "name": "Location Preferred",
    "begin_tag_display_position": {
      "x": 0,
      "y": 0
    },
    "start_node_id": "loc-location-check",
    "nodes": [
      {
        "id": "loc-location-check",
        "name": "Location Check",
        "type": "branch",
        "display_position": {
          "x": 100,
          "y": 200
        },
        "edges": [
          {
            "id": "e-loc-lc-1",
            "destination_node_id": "loc-validate-location",
            "transition_condition": {
              "type": "equation",
              "equations": [
                {
                  "left": "{{preferred_location}}",
                  "operator": "!=",
                  "right": ""
                }
              ],
              "operator": "||"
            }
          }
        ],
        "else_edge": {
          "id": "e-loc-lc-else",
          "destination_node_id": "loc-ask-location",
          "transition_condition": {
            "type": "prompt",
            "prompt": "Else"
          }
        }
      },
      {
        "id": "loc-ask-location",
        "name": "Ask Location",
        "type": "conversation",
        "display_position": {
          "x": 600,
          "y": 200
        },
        "instruction": {
          "type": "prompt",
          "text": "Ask which Premier MD location the caller would like to visit.\n\nSay something like: \"Which of our locations would be most convenient for you?\"\n\nMention that we have locations in: Elmhurst, Brooklyn, Manhattan, Flushing, SoHo Endo, and Great Neck.\n\nIf they're not sure, you can ask which area is closest to them or offer to help them decide based on their neighborhood.\n\nAccept any reasonable way they refer to the location:\n- By neighborhood name (\"Elmhurst\", \"Brooklyn\", \"Manhattan\", \"Flushing\", \"SoHo\", \"Great Neck\")\n- By area description (\"the one in Queens\", \"the one in Chinatown\", \"the Canal Street one\")\n- By abbreviated name (\"SoHo\", \"the surgery center\")"
        },
        "edges": [
          {
            "id": "e-loc-al-1",
            "destination_node_id": "loc-extract-location",
            "transition_condition": {
              "type": "prompt",
              "prompt": "Caller has indicated their preferred location"
            }
          },
          {
            "id": "e-loc-al-2",
            "destination_node_id": "loc-help-choose",
            "transition_condition": {
              "type": "prompt",
              "prompt": "Caller is unsure and needs help choosing a location"
            }
          }
        ]
      },
      {
        "id": "loc-help-choose",
        "name": "Help Choose Location",
        "type": "conversation",
        "display_position": {
          "x": 1100,
          "y": 400
        },
        "instruction": {
          "type": "prompt",
          "text": "Help the caller choose a location by asking which area is most convenient for them.\n\nProvide brief information about each location:\n\n**Elmhurst (Queens)**: 87-10 51st Ave, open Mon-Sun 8am-5pm\n**Brooklyn**: 761 55th St., open Mon-Sat 8:30am-5pm, Sun 9am-3pm\n**Manhattan (Chinatown)**: 198 Canal St., open Mon-Thu 8:30am-5pm, Fri-Sun by appointment\n**Flushing (Queens)**: 37-12 Prince St., open Mon-Sun with varying hours\n**SoHo Endo Surgery Center**: 168 Centre St., open Mon-Fri 8am-5pm, weekends by appointment\n**Great Neck (Long Island)**: 440-450 Northern Blvd, open Wed-Sat 8:30am-5pm\n\nAsk which area would be most convenient based on where they live or work."
        },
        "edges": [
          {
            "id": "e-loc-hc-1",
            "destination_node_id": "loc-extract-location",
            "transition_condition": {
              "type": "prompt",
              "prompt": "Caller has now chosen a location"
            }
          }
        ]
      },
      {
        "id": "loc-extract-location",
        "name": "Extract Location",
        "type": "extract_dynamic_variables",
        "display_position": {
          "x": 1600,
          "y": 200
        },
        "variables": [
          {
            "name": "preferred_location",
            "type": "string",
            "description": "The location the caller prefers. Extract as one of the following standardized values ONLY: 'elmhurst', 'brooklyn', 'manhattan', 'flushing', 'soho_endo', 'great_neck'. Map caller's response to the correct value: 'Elmhurst' or 'Queens near 51st' → 'elmhurst', 'Brooklyn' or '55th Street' → 'brooklyn', 'Manhattan' or 'Chinatown' or 'Canal Street' → 'manhattan', 'Flushing' or 'Prince Street' → 'flushing', 'SoHo' or 'surgery center' or 'Centre Street' → 'soho_endo', 'Great Neck' or 'Northern Boulevard' or 'Long Island' → 'great_neck'"
          }
        ],
        "else_edge": {
          "id": "e-loc-el-else",
          "destination_node_id": "loc-ask-location",
          "transition_condition": {
            "type": "prompt",
            "prompt": "Else"
          }
        },
        "edges": [
          {
            "id": "e-loc-el-1",
            "destination_node_id": "loc-validate-location",
            "transition_condition": {
              "type": "equation",
              "equations": [
                {
                  "left": "{{preferred_location}}",
                  "operator": "!=",
                  "right": ""
                }
              ],
              "operator": "||"
            }
          }
        ]
      },
      {
        "id": "loc-validate-location",
        "name": "Validate Location",
        "type": "function",
        "tool_type": "local",
        "tool_id": "tool-validate-location",
        "display_position": {
          "x": 2100,
          "y": 200
        },
        "instruction": {
          "type": "static_text",
          "text": "One moment..."
        },
        "speak_during_execution": true,
        "wait_for_result": true,
        "else_edge": {
          "id": "e-loc-vl-else",
          "destination_node_id": "loc-exit",
          "transition_condition": {
            "type": "prompt",
            "prompt": "Else"
          }
        },
        "edges": [
          {
            "id": "e-loc-vl-1",
            "destination_node_id": "loc-exit",
            "transition_condition": {
              "type": "equation",
              "equations": [
                {
                  "left": "{{location_valid}}",
                  "operator": "==",
                  "right": "true"
                }
              ],
              "operator": "||"
            }
          },
          {
            "id": "e-loc-vl-2",
            "destination_node_id": "loc-invalid-fallback",
            "transition_condition": {
              "type": "equation",
              "equations": [
                {
                  "left": "{{location_valid}}",
                  "operator": "==",
                  "right": "false"
                }
              ],
              "operator": "||"
            }
          }
        ]
      },
      {
        "id": "loc-invalid-fallback",
        "name": "Invalid Location Fallback",
        "type": "conversation",
        "display_position": {
          "x": 2600,
          "y": 400
        },
        "instruction": {
          "type": "prompt",
          "text": "The location provided doesn't match one of our Premier MD locations.\n\nPolitely say: \"I want to make sure I have the right location. Our locations are in Elmhurst, Brooklyn, Manhattan, Flushing, SoHo, and Great Neck. Which of these would work best for you?\"\n\nIf they mention a location we don't have, apologize and ask which of our actual locations would be most convenient."
        },
        "edges": [
          {
            "id": "e-loc-if-1",
            "destination_node_id": "loc-extract-location",
            "transition_condition": {
              "type": "prompt",
              "prompt": "Caller has clarified their location choice"
            }
          }
        ]
      },
      {
        "id": "loc-exit",
        "name": "Exit Component",
        "type": "end",
        "display_position": {
          "x": 2600,
          "y": 100
        },
        "instruction": {
          "type": "static_text",
          "text": "Location captured successfully"
        }
      }
    ],
    "tools": null,
    "user_modified_timestamp": null
  },
  "tool": {
    "tool_id": "tool-validate-location",
    "name": "validate_location",
    "type": "custom",
    "description": "Validates that the preferred location is one of the 6 Premier MD locations. Returns location details including address, phone, and hours.",
    "url": "https://smartsupport.ubiehealth.com/validation/location",
    "method": "POST",
    "headers": {},
    "query_params": {},
    "parameter_type": "json",
    "args_at_root": false,
    "timeout_ms": 5000,
    "speak_during_execution": false,
    "speak_after_execution": true,
    "parameters": {
      "type": "object",
      "required": ["location"],
      "properties": {
        "location": {
          "type": "string",
          "description": "The standardized location code: elmhurst, brooklyn, manhattan, flushing, soho_endo, or great_neck"
        }
      }
    },
    "response_variables": {
      "location_valid": "valid",
      "location_address": "address",
      "location_phone": "phone",
      "location_hours": "hours",
      "location_error": "error"
    }
  },
  "default_dynamic_variables": {
    "preferred_location": "",
    "location_valid": "",
    "location_address": "",
    "location_phone": "",
    "location_hours": "",
    "location_error": ""
  },
